    "input_epoch = input_data.iloc[0,:].to_numpy()\n",
    "template_list = ['SN2005cs_modelspectra/cs0_1_l1b_B1_v1_2.fl',\n",
    "                 'SN2005cs_modelspectra/cs0_1_l1b_B1_v1_5.fl',\n",
