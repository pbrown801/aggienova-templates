    "bbwave=np.arange(1000, 10000, 10)\n",
    "temp=5000\n",
    "\n",
    "def bbspec_arrays(temp, bbwave):\n",
    "\n",
    "    w = bbwave / 1.E8        # Angstroms to cm    \n",
    "    #constants appropriate to cgs units.\n",
    "    c1 =  3.7417749**(-5)     # =2*h*c*c       \n",
    "    c2 =  1.4387687           # =h*c/k\n",
    "    val =  c2/w/temp  \n",
    "    bbflux =  c1 / ( w**5.0 * ( np.exp( val)-1.0 ) )\n",
    "    \n",
    "    return(bbwave,bbflux)\n",
    "\n"
   ]
  },
