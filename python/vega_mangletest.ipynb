    "filtereffwavelength=[2030,2231,2634,3501,4329,5402] ### EFFECTIVE VEGA WAVELENGTH FOR EACH FILTER (IN SAME ORDER)\n",
    "filtereffwavelength=np.array(filtereffwavelength,dtype=float) ### EFFECTIVE VEGA WAVELENGTH FOR EACH FILTER (IN SAME ORDER)\n",
